---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const h = messages.hero;
---

<section class="relative min-h-[78vh] sm:min-h-[88vh] flex items-center justify-center text-center overflow-hidden">
  <div class="absolute inset-0" style={`background-image: linear-gradient(rgba(15,32,21,0.55), rgba(15,32,21,0.55)), url('/gallery/faro-monumental-de-la-serena-1.jpg'); background-size: cover; background-position: center;`}></div>
  <div class="relative z-10 px-4 sm:px-6 py-16 sm:py-20 max-w-3xl animate-fade-in-up">
    <span class="inline-flex max-w-full flex-wrap items-center justify-center gap-1 px-3 py-1 mb-5 rounded-full text-xs sm:text-sm font-medium" style="background: rgba(255,255,255,0.15); color: #fff; backdrop-filter: blur(4px);">
      ⭐ {h.rating} · {h.reviewCount}
    </span>
    <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight mb-5">
      {h.title}
    </h1>
    <p class="text-base sm:text-xl text-white/90 mb-4 max-w-2xl mx-auto leading-relaxed">
      {h.subtitle}
    </p>
    <p class="text-sm text-white/80 mb-8 inline-flex items-center justify-center gap-2 flex-wrap">
      🕒 {h.hours}
    </p>
    <div class="flex justify-center">
      <a href={h.mapsUrl} target="_blank" rel="noopener noreferrer"
         class="inline-flex w-full sm:w-auto justify-center px-8 py-3.5 rounded-full font-semibold text-white shadow-lg hover:opacity-90 transition"
         style="background: var(--accent);">
        📍 {h.openMaps}
      </a>
    </div>
  </div>
</section>
