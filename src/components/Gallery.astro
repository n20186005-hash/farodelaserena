---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const g = messages.gallery;
const images = Array.from({ length: 20 }, (_, i) => `/gallery/faro-monumental-de-la-serena-${i + 1}.jpg`);
---

<section id="gallery" class="section-padding" style="background: var(--bg-secondary);">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3 text-center" style="color: var(--text-primary);">{g.title}</h2>
    <p class="text-center text-lg mb-10" style="color: var(--text-secondary);">{g.subtitle}</p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" id="gallery-grid">
      {images.map((src) => (
        <div class="gallery-item">
          <img src={src} alt={g.photoAlt} loading="lazy" class="w-full h-56 object-cover" />
        </div>
      ))}
    </div>

    <div class="text-center mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a href={g.mapsUrl} target="_blank" rel="noopener noreferrer" class="px-6 py-3 rounded-full font-semibold text-white" style="background: var(--accent);">
        📍 {g.viewAll}
      </a>
    </div>
  </div>
</section>
