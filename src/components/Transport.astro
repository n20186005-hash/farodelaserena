---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const section = messages.transportSection;
---

<section id="transport" class="section-padding" style="background: var(--bg-secondary);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3" style="color: var(--text-primary);">{section.title}</h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">{section.subtitle}</p>
    </div>

    <div class="rounded-2xl p-6 md:p-8 border mb-8" style="background: var(--bg-tertiary); border-color: var(--border-color);">
      <div class="grid lg:grid-cols-[1.25fr_0.75fr] gap-6 items-start">
        <div>
          <h3 class="font-semibold text-xl mb-3" style="color: var(--text-primary);">{section.overviewTitle}</h3>
          <p class="text-base leading-relaxed" style="color: var(--text-secondary);">{section.overviewText}</p>
        </div>
        <div class="rounded-2xl p-5 border" style="background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--card-shadow);">
          <h3 class="font-semibold mb-3" style="color: var(--text-primary);">{section.arrivalTitle}</h3>
          <ul class="space-y-3 text-sm" style="color: var(--text-secondary);">
            {section.arrivalItems.map((item) => (
              <li class="flex gap-3"><span style="color: var(--accent);">•</span><span>{item}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
      {section.modes.map((mode, index) => (
        <article class="rounded-2xl p-6 border h-full" style="background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--card-shadow);">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold" style="background: var(--accent); color: white;">
              {String(index + 1).padStart(2, '0')}
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.18em]" style="color: var(--text-muted);">{mode.label}</p>
              <h3 class="font-semibold text-xl" style="color: var(--text-primary);">{mode.title}</h3>
            </div>
          </div>
          <p class="text-base leading-relaxed mb-4" style="color: var(--text-secondary);">{mode.description}</p>
          <ul class="space-y-3 text-sm" style="color: var(--text-secondary);">
            {mode.details.map((detail) => (
              <li class="flex gap-3"><span style="color: var(--accent);">-</span><span>{detail}</span></li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="grid lg:grid-cols-[1fr_auto] gap-6 items-center mt-10 rounded-2xl p-6 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
      <div>
        <h3 class="font-semibold text-xl mb-3" style="color: var(--text-primary);">{section.localTipsTitle}</h3>
        <ul class="space-y-3 text-base" style="color: var(--text-secondary);">
          {section.localTips.map((item) => (
            <li class="flex gap-3"><span style="color: var(--accent);">✓</span><span>{item}</span></li>
          ))}
        </ul>
      </div>
      <div class="text-left lg:text-right">
        <a href={section.mapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto justify-center px-8 py-3 rounded-full font-semibold text-white" style="background: var(--accent);">
          {section.mapsCta}
        </a>
      </div>
    </div>
  </div>
</section>
