---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const t = messages.knowledge;
const sections = t.sections;
---

<section id="history" class="section-padding" style="background: var(--bg-primary);">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-6 text-center" style="color: var(--text-primary);">{t.title}</h2>
    <div class="w-12 h-0.5 mb-12 mx-auto" style="background: var(--accent);"></div>

    <div class="space-y-12">
      {sections.map((section, index) => (
        <div class={`flex flex-col md:flex-row gap-6 items-start ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
          <div class="flex-1 w-full bg-white/5 p-8 rounded-2xl border border-white/10 shadow-sm">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg" style="background: var(--accent); color: white;">
                {index + 1}
              </div>
              <h3 class="font-display text-2xl font-semibold" style="color: var(--text-primary);">{section.title}</h3>
            </div>
            <p class="text-lg leading-relaxed ml-14" style="color: var(--text-secondary);">{section.content}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
